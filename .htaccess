# Internal rewrite so Apache serves Laravel from /public without exposing
# the directory in the URL. Required when the App Service document root is
# the repo root (default for Azure App Service Linux PHP).
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Don't loop on requests that already target /public/.
    RewriteCond %{REQUEST_URI} !^/public/

    # Send everything else into /public/ via internal rewrite.
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Belt-and-suspenders: deny direct access to dotfiles and source-control debris
# in case Apache's directory traversal protections are loosened.
<FilesMatch "^\.(env|env\..*|git.*|htaccess)$">
    Require all denied
</FilesMatch>

<FilesMatch "(composer\.(json|lock)|package(-lock)?\.json|artisan|\.gitattributes|\.gitignore)$">
    Require all denied
</FilesMatch>
